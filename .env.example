# Supabase — client-side (safe to expose)
VITE_SUPABASE_URL=https://jzbqicxycryebennqyhe.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Stripe — publishable key is client-side (safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here

# Stripe — secret key is SERVER-SIDE ONLY (never use VITE_ prefix for secrets)
# Used by api/create-checkout-session.js (Vercel serverless function)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here

# Tremendous — for gift card delivery
