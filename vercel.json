{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/stripe-webhook.js": {
      "maxDuration": 10
    },
    "api/create-checkout-session.js": {
      "maxDuration": 10
    }
  }
}
